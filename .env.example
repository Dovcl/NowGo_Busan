# backend/.env.example
# 실제 .env 파일은 절대 GitHub에 올리지 않는다.
# 이 파일만 커밋한다.

# ────────────────────────────────────────
# 한국관광공사 OpenAPI
# ────────────────────────────────────────
TOUR_API_KEY=your_tour_api_key_here
# 공공데이터포털 일련번호: 15101578
# BaseURL: https://apis.data.go.kr/B551011/KorService2

TOURDATA_API_KEY=your_tourdata_api_key_here
# 관광빅데이터 정보서비스 (외국인 펄스)
# 공공데이터포털 일련번호: 15101972
# BaseURL: https://apis.data.go.kr/B551011/DataLabService

# ────────────────────────────────────────
# 환경 공공 API
# ────────────────────────────────────────
AIR_KOREA_API_KEY=your_air_korea_key_here
# 한국환경공단 에어코리아 대기오염정보

WEATHER_API_KEY=your_weather_api_key_here
# 기상청 단기예보 (VilageFcstInfoService)
# 기상청 생활기상지수 (3.0)

OCEAN_API_KEY=your_ocean_api_key_here
# 국립해양조사원 이안류 전용 API
# BaseURL: https://apis.data.go.kr/1192136/ripCurrent

WATER_QUALITY_API_KEY=your_water_quality_key_here
# 환경부 국립환경과학원 수질 DB

# ────────────────────────────────────────
# 카카오 생태계
# ────────────────────────────────────────
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
# 카카오 REST API (서버 사이드: 카카오 로컬, 카카오 모빌리티 Directions)

KAKAO_JS_API_KEY=your_kakao_js_api_key_here
# 카카오 JavaScript API (프론트엔드: 카카오맵 Web API)
# 주의: 프론트엔드에서만 사용, 도메인 등록 필수

KAKAO_CLIENT_ID=your_kakao_client_id_here
# 카카오톡 OAuth 로그인

KAKAO_CLIENT_SECRET=your_kakao_client_secret_here

# ────────────────────────────────────────
# 데이터베이스 (PostGIS)
# ────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nowgo_busan

# ────────────────────────────────────────
# Redis (캐시 + ETL 쿼터 관리)
# ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ────────────────────────────────────────
# 앱 설정
# ────────────────────────────────────────
MOCK_MODE=true
# true: 실제 API 호출 없이 mock 데이터로 개발
# false: 실제 API 호출

ENVIRONMENT=development
# development | production

SECRET_KEY=your_secret_key_here
# FastAPI 세션/JWT 서명용

CORS_ORIGINS=http://localhost:5173
# 프론트엔드 dev 서버 주소 (production에서는 실제 도메인)
